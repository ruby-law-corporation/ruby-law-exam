OPENAI_API_KEY=
# Model used for analysis (optional — defaults to gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini
# API server
PORT=3001
# Single origin allowed for CORS
WEB_ORIGIN=http://localhost:5173
# Web app — base URL of the API (consumed by Vite, must be prefixed with VITE_)
VITE_API_URL=http://localhost:3001
# Postgres connection string (used by Prisma). Matches the docker-compose service.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/contracts?schema=public
