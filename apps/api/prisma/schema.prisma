generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Contract {
  id              String   @id
  filename        String
  isContract      Boolean
  type            String
  riskScore       Int
  missingClauses  String[]
  recommendations String[]
  createdAt       String
}
